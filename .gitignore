# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# ── Virtual environments ───────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Secrets & credentials ─────────────────────────────────
.env
.env.*
!.env.example
secrets.yaml
secrets.yml
profiles.yml          # DBT — contains DB password, never commit

# ── Raw & processed data (too large / sensitive) ──────────
data/raw/
data/processed/
*.csv
*.parquet
*.xlsx
*.json
!data/sample/         # sample data IS committed (small, anonymised)

# ── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── DBT ───────────────────────────────────────────────────
dbt/hydera_analytics/target/
dbt/hydera_analytics/dbt_packages/
dbt/hydera_analytics/logs/

# ── Power BI ──────────────────────────────────────────────
# Commit the .pbix (it is the dashboard deliverable)
# Exclude auto-generated lock files if any appear
*.pbix.lock

# ── OS junk ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~

# ── IDE ───────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
